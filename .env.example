# Copia a .env: cp .env.example .env
#
# Puertos:
#   Local (pnpm dev): 5173
#   Docker Compose:   5173 (variables en kinalsports-stack/.env.docker)

# API de autenticacion (auth-service)
VITE_AUTH_URL=http://localhost:5156/api/v1

# API de administracion (server-admin)
VITE_ADMIN_URL=http://localhost:3009/kinalSportsAdmin/v1

# Base de Cloudinary para imagenes (opcional)
VITE_CLOUDINARY_BASE_URL=https://res.cloudinary.com/your-cloud-name/image/upload/
